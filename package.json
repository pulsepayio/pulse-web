{
  "name": "pulse",
  "version": "1.0.0",
  "description": "Pulse - Real-time bank payment infrastructure",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc && (xcopy src\\views dist\\views /Y /E /I 2>nul || cp -r src/views dist/views 2>/dev/null || true)",
    "start": "prisma db push --skip-generate && node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^16.3.0",
    "bcryptjs": "^2.4.3",
    "bitcoinjs-lib": "^7.0.1",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.5",
    "ecpair": "^3.0.1",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "js-sha3": "^0.12.0",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.7",
    "node-cron": "^3.0.3",
    "nodemailer": "^9.0.3",
    "stripe": "^14.13.0",
    "tiny-secp256k1": "^2.2.4",
    "tronweb": "^6.4.0",
    "uuid": "^10.0.0",
    "wif": "^5.0.0",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@types/uuid": "^10.0.0",
    "@types/wif": "^2.0.5",
    "prisma": "^5.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.0"
  }
}
